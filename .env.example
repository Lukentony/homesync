# Genera con: openssl rand -hex 32
SECRET_KEY=openssl_rand_hex_32

# Nomi e token degli utenti — usati dalla migrazione 001 per il seed iniziale
USER_A_ID=1
USER_A_NAME=NomeA
USER_A_TOKEN=token_a_segreto
USER_B_ID=2
USER_B_NAME=NomeB
USER_B_TOKEN=token_b_segreto

PUBLIC_BASE_URL=https://homesync.tuodominio.com
INTERNAL_BASE_URL=http://localhost:8000
DATABASE_PATH=/data/homesync.db
IDEMPOTENCY_WINDOW_SECONDS=60
APP_NAME=HomeSync
APP_VERSION=2.0.0
HOMESYNC_VERSION=1.0.0

# Abilita endpoint di test distruttivi (reset-test, generate-test-data)
# NON impostare a true in produzione
DEBUG=false

# Chiave API per integrazione n8n (opzionale, senza il router n8n dà 403)
N8N_API_KEY=
